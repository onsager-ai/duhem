/target
**/*.rs.bk
*.swp
*.swo
.DS_Store
.idea/
.vscode/
tmp/

# Local Duhem run evidence (written by `duhem run`). Root-anchored so a
# committed `.duhem/` VD suite (Pattern D, `templates/product-repo/`) is
# NOT swallowed by this rule; `*.db` catches evidence written into any
# nested `.duhem/` too. Product repos adopting the `.duhem/` layout want
# the same narrow pattern — ignore the DB, commit the VDs.
/.duhem/
.duhem/*.db
.duhem/*.db-*

# Dashboard SPA toolchain output (built in CI; build.rs writes a
# placeholder when absent)
crates/duhem-dashboard/web/node_modules/
crates/duhem-dashboard/web/dist/
