{
  "$comment": "Single source of truth for the npm distribution pipeline. Consumed by the scripts under npm/scripts/*.mjs and mirrored by the build matrix in .github/workflows/release.yml. The rust-npm-publish skill's publish.config.ts, expressed as plain JSON so the pipeline needs no TS toolchain.",
  "scope": "@duhem",
  "binaryNames": ["duhem", "duhem-dashboard"],
  "cargoWorkspace": "Cargo.toml",
  "repositoryUrl": "git+https://github.com/onsager-ai/duhem.git",
  "mainPackage": {
    "dir": "npm/duhem",
    "name": "duhem"
  },
  "platformDir": "npm/platforms",
  "$platformNote": "`platform` is the canonical key for the CI build matrix + the `binary-<platform>` artifact name (also the dir suffix). `nodeKey` is the `${process.platform}-${process.arch}` value bin.js maps at runtime; it differs from `platform` only for Windows (win32-x64 vs windows-x64).",
  "platforms": [
    {
      "package": "@duhem/cli-linux-x64",
      "dir": "cli-linux-x64",
      "platform": "linux-x64",
      "nodeKey": "linux-x64",
      "os": "linux",
      "cpu": "x64",
      "target": "x86_64-unknown-linux-gnu",
      "ext": ""
    },
    {
      "package": "@duhem/cli-linux-arm64",
      "dir": "cli-linux-arm64",
      "platform": "linux-arm64",
      "nodeKey": "linux-arm64",
      "os": "linux",
      "cpu": "arm64",
      "target": "aarch64-unknown-linux-gnu",
      "ext": ""
    },
    {
      "package": "@duhem/cli-darwin-x64",
      "dir": "cli-darwin-x64",
      "platform": "darwin-x64",
      "nodeKey": "darwin-x64",
      "os": "darwin",
      "cpu": "x64",
      "target": "x86_64-apple-darwin",
      "ext": ""
    },
    {
      "package": "@duhem/cli-darwin-arm64",
      "dir": "cli-darwin-arm64",
      "platform": "darwin-arm64",
      "nodeKey": "darwin-arm64",
      "os": "darwin",
      "cpu": "arm64",
      "target": "aarch64-apple-darwin",
      "ext": ""
    },
    {
      "package": "@duhem/cli-windows-x64",
      "dir": "cli-windows-x64",
      "platform": "windows-x64",
      "nodeKey": "win32-x64",
      "os": "win32",
      "cpu": "x64",
      "target": "x86_64-pc-windows-msvc",
      "ext": ".exe"
    }
  ]
}
